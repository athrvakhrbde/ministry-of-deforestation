# Public site URL (Vercel sets this automatically; override for custom domain)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Mapbox — optional; uses free Carto dark tiles when empty
NEXT_PUBLIC_MAPBOX_TOKEN=

# Supabase — Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Server-only — NEVER expose as NEXT_PUBLIC_
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# News ingest cron (twice daily via Vercel cron or manual npm run ingest)
CRON_SECRET=generate_a_random_secret_here
# Set to false to disable auto-sync on first page load
INGEST_AUTO_SYNC=true
